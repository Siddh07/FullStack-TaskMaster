{
    "version": 2,
    "builds": [
      {
        "src": "vite.config.ts",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
      }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "https://your-backend-host.com/api/$1" },
      { "src": "/(.*)", "dest": "/" }
    ]
  }